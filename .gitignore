# --- DATA & BINARIES ---
# Ignore all CSVs, Pickles, and Numpy files everywhere
*.csv
!docs/literature.csv
*.pkl
*.npy
*.npz
*.pt
*.h5

# Specific large folders
datasets/            # raw data — never commit (sensitive / large)
data/**              # graph cache
references/**/data/
outputs/
models/

# --- ENVIRONMENT ---
venv/
.venv/
bin/
lib/
include/

# --- IDE & SYSTEM ---
.DS_Store
.vscode/
.idea/
.ipynb_checkpoints/
__pycache__/
*.log
*.pyc
*.pyo
*.pyd

# --- EXPERIMENT TRACKING ---
wandb/
runs/
tensorboard/
mlruns/

# --- OUTPUTS ---
*.png
*.jpg
*[Ss][Ee][Nn][Ss][Ii][Tt][Ii][Vv][Ee]*.pdf

# --- RESULTS ---
# Allow markdown result logs in results/
!results/**/*.md

# --- LATEX BUILD ARTIFACTS ---
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.toc
paper/build/

# --- WORKING DOCS (may contain sensitive content) ---
doc_workspace.md

# --- TEMPORARY FILES ---
*.swp
*.swo
*~
.cache/