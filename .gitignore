# --- DATA & BINARIES ---
# Ignore all CSVs, Pickles, and Numpy files everywhere
*.csv
*.pkl
*.npy
*.npz
*.pt
*.h5

# Specific large folders
data/**
references/**/data/
outputs/
models/

# --- ENVIRONMENT ---
venv/
.venv/
bin/
lib/
include/

# --- IDE & SYSTEM ---
.DS_Store
.vscode/
.idea/
.ipynb_checkpoints/
__pycache__/
*.log
*.pyc
*.pyo
*.pyd

# --- EXPERIMENT TRACKING ---
wandb/
runs/
tensorboard/
mlruns/

# --- OUTPUTS ---
*.png
*.jpg
*[Ss][Ee][Nn][Ss][Ii][Tt][Ii][Vv][Ee]*.pdf
!*.pdf
!docs/*.png
!docs/*.jpg

# --- RESULTS ---
